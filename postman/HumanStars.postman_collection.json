{
  "info": {
    "name": "HumanStars API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API collection for HumanStars calendar module.\n\nWorkflow:\n1. Run **Login** — token is saved automatically.\n2. Run **Create Calendar** — calendar_id is saved automatically.\n3. Run **Create Event** — event_id is saved automatically.\n4. Run **Invite User** — invitee_id is saved automatically.\n\nSet `base_url` to your local or production URL before running."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "calendar_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "event_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "invitee_id",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved:', json.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate a user and retrieve a JWT token. The token is automatically saved to the `token` collection variable."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Return the currently authenticated user's profile."
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('token', '');",
                  "    console.log('Token cleared.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Invalidate the current JWT token. The `token` variable is cleared automatically."
          }
        }
      ]
    },
    {
      "name": "Calendars",
      "item": [
        {
          "name": "List Calendars",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars"]
            },
            "description": "Returns all calendars split into `owned` and `shared` arrays."
          }
        },
        {
          "name": "Create Calendar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('calendar_id', json.id);",
                  "    console.log('Calendar ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Work\",\n  \"color\": \"#3B82F6\",\n  \"description\": \"Work-related meetings and deadlines.\",\n  \"timezone\": \"Europe/London\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars"]
            },
            "description": "Create a new calendar. The new calendar's ID is saved to `calendar_id` automatically.\n\n**Fields:**\n- `name` (required)\n- `color` (optional) — hex, e.g. `#3B82F6`\n- `description` (optional)\n- `timezone` (optional) — IANA timezone, defaults to `UTC`"
          }
        },
        {
          "name": "Get Calendar",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}"]
            },
            "description": "Retrieve a single calendar. Requires ownership or a share."
          }
        },
        {
          "name": "Update Calendar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Work (Updated)\",\n  \"color\": \"#10B981\",\n  \"timezone\": \"America/New_York\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}"]
            },
            "description": "Update a calendar. All fields optional. Requires ownership or READWRITE share."
          }
        },
        {
          "name": "Delete Calendar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}"]
            },
            "description": "Soft-delete a calendar. Owner only."
          }
        }
      ]
    },
    {
      "name": "Calendar Events",
      "item": [
        {
          "name": "List Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events?from=2026-04-01&to=2026-12-31",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events"],
              "query": [
                {
                  "key": "from",
                  "value": "2026-04-01",
                  "description": "Filter events with starts_at >= this date (optional)"
                },
                {
                  "key": "to",
                  "value": "2026-12-31",
                  "description": "Filter events with ends_at <= this date (optional)"
                }
              ]
            },
            "description": "List events ordered by `starts_at`. Both `from` and `to` are optional."
          }
        },
        {
          "name": "Create Event — On-site",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('event_id', json.id);",
                  "    console.log('Event ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Team Offsite\",\n  \"description\": \"Quarterly planning session.\",\n  \"type\": \"on-site\",\n  \"address\": \"30 St Mary Axe, London EC3A 8BF, UK\",\n  \"starts_at\": \"2026-04-10 09:00:00\",\n  \"ends_at\": \"2026-04-10 17:00:00\",\n  \"timezone\": \"Europe/London\",\n  \"reminder_minutes\": 30\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events"]
            },
            "description": "Create an on-site event. `address` is optional and triggers async geocoding — `latitude`/`longitude` are filled in the background and never exposed in responses.\n\n**Fields:**\n- `title` (required)\n- `type` (required) — `on-site` or `virtual`\n- `address` (optional) — geocoded automatically\n- `starts_at` / `ends_at` (required) — UTC datetimes\n- `timezone` (optional) — IANA override for this event\n- `rrule` (optional) — RFC 5545, e.g. `FREQ=WEEKLY;BYDAY=MO`\n- `reminder_minutes` (optional) — triggers a reminder email that many minutes before start"
          }
        },
        {
          "name": "Create Event — Virtual",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('event_id', json.id);",
                  "    console.log('Event ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Weekly Standup\",\n  \"description\": \"Monday sync.\",\n  \"type\": \"virtual\",\n  \"meeting_url\": \"https://meet.example.com/standup\",\n  \"starts_at\": \"2026-04-07 09:00:00\",\n  \"ends_at\": \"2026-04-07 09:30:00\",\n  \"rrule\": \"FREQ=WEEKLY;BYDAY=MO\",\n  \"reminder_minutes\": 10\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events"]
            },
            "description": "Create a virtual event. `meeting_url` is required when `type` is `virtual`."
          }
        },
        {
          "name": "Get Event",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}"]
            },
            "description": "Retrieve a single event. `latitude` and `longitude` are never included in the response."
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Team Offsite (Updated)\",\n  \"address\": \"1 Canada Square, London E14 5AB, UK\",\n  \"reminder_minutes\": 60\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}"]
            },
            "description": "Update an event. All fields optional. Changing `address` on an on-site event re-triggers geocoding asynchronously."
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}"]
            },
            "description": "Soft-delete an event. Requires ownership or READWRITE share on the parent calendar."
          }
        }
      ]
    },
    {
      "name": "Event Invitees",
      "item": [
        {
          "name": "List Invitees",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}/invitees",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}", "invitees"]
            },
            "description": "List all invitees for an event. Accessible by the calendar owner, READWRITE share-holders, and the invited users themselves."
          }
        },
        {
          "name": "Invite User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('invitee_id', json.id);",
                  "    console.log('Invitee ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteable_type\": \"user\",\n  \"inviteable_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}/invitees",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}", "invitees"]
            },
            "description": "Invite a user to the event. The invitee_id is saved automatically.\n\n**Fields:**\n- `inviteable_type` (required) — `user` or `group`\n- `inviteable_id` (required) — ID of the user or group\n\nDuplicates are rejected. Requires ownership or READWRITE share."
          }
        },
        {
          "name": "Invite Group",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('invitee_id', json.id);",
                  "    console.log('Invitee ID saved:', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inviteable_type\": \"group\",\n  \"inviteable_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}/invitees",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}", "invitees"]
            },
            "description": "Invite an entire group to the event. All group members receive reminder emails when the event reminder fires.\n\nRequires ownership or READWRITE share."
          }
        },
        {
          "name": "Update RSVP Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}/invitees/{{invitee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}", "invitees", "{{invitee_id}}"]
            },
            "description": "Update the RSVP status of an invitee record.\n\n**Fields:**\n- `status` (required) — `pending`, `accepted`, or `declined`\n\n**Access rules:**\n- The invited user can update their own record.\n- The calendar owner / READWRITE share-holder can update any record.\n\nOnly `accepted` invitees receive reminder emails."
          }
        },
        {
          "name": "Remove Invitee",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/api/calendars/{{calendar_id}}/events/{{event_id}}/invitees/{{invitee_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "calendars", "{{calendar_id}}", "events", "{{event_id}}", "invitees", "{{invitee_id}}"]
            },
            "description": "Remove an invitee from the event. Requires ownership or READWRITE share on the parent calendar."
          }
        }
      ]
    }
  ]
}
